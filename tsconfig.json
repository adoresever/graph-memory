{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "openclaw/plugin-sdk": ["./src/openclaw-stub.ts"]
    }
  },
  "include": ["src/**/*.ts", "index.ts"],
  "exclude": ["test/**/*.ts", "dist", "node_modules"]
}
