    "openai": "^4.47.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "execa": "^9.5.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ]
